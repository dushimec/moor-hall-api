# Server Configuration
PORT=3005
NODE_ENV=production
BACKEND_URL=https://your-api-domain.vercel.app
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Database (Required - Set up a cloud PostgreSQL database)
# Recommended: Neon, Supabase, Railway, or AWS RDS
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# JWT Secrets (Generate secure random strings)
JWT_SECRET="your-secure-jwt-secret-key-minimum-32-characters"
JWT_REFRESH_SECRET="your-secure-refresh-secret-key-minimum-32-characters"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Google OAuth (Optional - for admin authentication)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudinary (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio (Optional - for SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER="+1234567890"

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pindo (Optional - for SMS in certain regions)
PINDO_ACCESS_TOKEN=your-pindo-token
PINDO_SENDER_ID=YourSenderID

# Firebase (Optional - for push notifications)
FIREBASE_SERVICE_JSON_PATH=path-to-firebase-service-account.json

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-...

# Google Maps (Optional - for location services)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SERVER_MAPS_API_KEY=your-server-maps-api-key

# Internal Service Token
INTERNAL_SERVICE_TOKEN=your-internal-secure-token

# WhatsApp Cloud API (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_DEFAULT_COUNTRY_CODE=250

# Cookie Configuration (for production)
COOKIE_DOMAIN=your-domain.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
